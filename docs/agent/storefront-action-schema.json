{
  "openapi": "3.1.0",
  "info": {
    "title": "GEM Storefront Access API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://support371-gem-enterprise.vercel.app"
    }
  ],
  "paths": {
    "/api/agent/public/commerce": {
      "get": {
        "operationId": "getGemPublicStorefront",
        "summary": "Get an approved GEM storefront",
        "parameters": [
          {
            "name": "channel",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["tiktok", "google"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Storefront routing response"
          }
        }
      }
    }
  }
}

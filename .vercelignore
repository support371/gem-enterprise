# Supabase local tooling is not needed during application builds. Retain only
# the governed gateway sources and their credential migration because
# repository verification reads them to enforce security invariants.
supabase/*
!supabase/functions/
!supabase/migrations/

supabase/functions/*
!supabase/functions/gem-auth-gateway/
!supabase/functions/gem-admin-write/
!supabase/functions/gem-tokmetric-gpt-gateway/
!supabase/functions/gem-tokmetric-agent-gateway/
!supabase/functions/gem-tokmetric-command-gateway/

supabase/functions/gem-auth-gateway/*
!supabase/functions/gem-auth-gateway/index.ts
!supabase/functions/gem-auth-gateway/deno.json

supabase/functions/gem-admin-write/*
!supabase/functions/gem-admin-write/index.ts

supabase/functions/gem-tokmetric-gpt-gateway/*
!supabase/functions/gem-tokmetric-gpt-gateway/index.ts
!supabase/functions/gem-tokmetric-gpt-gateway/deno.json

supabase/functions/gem-tokmetric-agent-gateway/*
!supabase/functions/gem-tokmetric-agent-gateway/index.ts
!supabase/functions/gem-tokmetric-agent-gateway/deno.json

supabase/functions/gem-tokmetric-command-gateway/*
!supabase/functions/gem-tokmetric-command-gateway/index.ts
!supabase/functions/gem-tokmetric-command-gateway/deno.json

supabase/migrations/*
!supabase/migrations/20260716140000_create_tokmetric_gpt_credentials.sql

# Documentation is excluded from deployment bundles
*.md
DEPLOYMENT.md

# Keep governance records required by build-time verification.
!prisma/proposals/README.md
!docs/PUBLIC_CLAIMS_REVIEW.md

# Local environment templates are not deployed
.env.example

# Editor and workstation artifacts
.idea/
.vscode/
.DS_Store
bun.lock
bun.lockb

# Supabase local tooling is not needed during application builds. Keep only the two
# authentication function sources required by release verification.
supabase/*
!supabase/functions/
supabase/functions/*
!supabase/functions/gem-auth-gateway/
!supabase/functions/gem-password-recovery/
supabase/functions/gem-auth-gateway/*
!supabase/functions/gem-auth-gateway/index.ts
!supabase/functions/gem-auth-gateway/deno.json
supabase/functions/gem-password-recovery/*
!supabase/functions/gem-password-recovery/index.ts
!supabase/functions/gem-password-recovery/deno.json

# Documentation is excluded from deployment bundles
*.md
DEPLOYMENT.md

# Keep governance records required by build-time verification.
!prisma/proposals/README.md
!docs/PUBLIC_CLAIMS_REVIEW.md

# Local environment templates are not deployed
.env.example

# Editor and workstation artifacts
.idea/
.vscode/
.DS_Store
bun.lock
bun.lockb

# =============================================================================
# GEM Enterprise — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://gem-enterprise.com
NEXT_PUBLIC_APP_NAME=GEM Enterprise
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://username:password@localhost:5432/gem_enterprise

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Must be at least 32 characters. Use `openssl rand -hex 32` to generate.
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# -----------------------------------------------------------------------------
# Admin Bootstrap
# -----------------------------------------------------------------------------
# Used by the seed script to create the initial admin account.
# Change the password immediately after first login.
ADMIN_EMAIL=admin@gem-enterprise.com
ADMIN_INITIAL_PASSWORD=change-me-on-first-login

# -----------------------------------------------------------------------------
# Email / SMTP
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@gem-enterprise.com
SMTP_PASS=smtp-password
EMAIL_FROM=GEM Enterprise <noreply@gem-enterprise.com>

# -----------------------------------------------------------------------------
# Audit Logging
# -----------------------------------------------------------------------------
# Set to "true" to enable structured audit logs for compliance events.
AUDIT_ENABLED=true

# -----------------------------------------------------------------------------
# Vercel (auto-injected — do not set manually)
# -----------------------------------------------------------------------------
# VERCEL_URL is automatically set by the Vercel runtime.
# VERCEL_ENV is automatically set to "production", "preview", or "development".

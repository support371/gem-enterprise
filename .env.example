# =============================================================================
# GEM Enterprise — Environment Variable Template
# =============================================================================
# Copy this file to .env.local and fill in real values before running locally.
# Never commit .env.local or any file that contains real secrets.
#
# For Vercel deployment: add these variables in
# Vercel Dashboard → Project → Settings → Environment Variables
# Do NOT paste secrets into vercel.json — use Vercel Project Settings only.
# =============================================================================

# --- Database ----------------------------------------------------------------
POSTGRES_PRISMA_URL=postgresql://username:password@localhost:5432/gem_enterprise
POSTGRES_URL_NON_POOLING=postgresql://username:password@localhost:5432/gem_enterprise

# --- Authentication ----------------------------------------------------------
# Must be at least 32 characters in production.
# GEM derives domain-separated internal scanner credentials from this secret.
JWT_SECRET=replace-this-with-a-random-32-char-secret
# Separate signing secret recommended for 15-minute password reset links.
# When omitted, the application falls back to JWT_SECRET.
PASSWORD_RESET_SECRET=replace-this-with-a-different-random-32-char-secret

# --- AI / Governed Chat ------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-replace-with-real-key
NEXT_PUBLIC_AI_DISCLOSURE_TEXT=GEM Concierge is an AI assistant. It does not provide legal, financial, or investment advice. Responses are for informational purposes only. For regulated matters, speak with a qualified advisor.

# --- Application -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-deployment-url.vercel.app
NEXT_PUBLIC_APP_NAME=GEM Enterprise

# --- Platform Operations Agent ----------------------------------------------
# Private API key used by the Platform Operations Agent Action.
# Use a randomly generated value of at least 32 characters.
GEM_AGENT_API_KEY=replace-with-random-agent-key-at-least-32-characters
# Public website shown in agent responses.
GEM_PUBLIC_APP_URL=https://www.gemcybersecurityassist.com
# Stable Vercel or API-subdomain origin serving /api/agent/*.
GEM_AGENT_API_BASE_URL=https://support371-gem-enterprise.vercel.app
# Keep false until each external commerce account is formally authorized.
TIKTOK_SELLER_ACCOUNT_CONNECTED=false
GOOGLE_MERCHANT_ACCOUNT_CONNECTED=false

# --- Email / SMTP ------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-smtp-password
EMAIL_FROM=GEM Enterprise <noreply@example.com>
REPLY_TO_EMAIL=support@example.com

# --- GEM Verify Secure Evidence Vault ---------------------------------------
# Server-only Supabase Storage access. Never expose the service role key to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
# Use GEM's first-party structural file-safety scanner.
GEM_VERIFY_SCANNER_MODE=first_party
GEM_VERIFY_SCANNER_URL=https://www.gemcybersecurityassist.com/api/verify/evidence/internal-scanner
GEM_VERIFY_PUBLIC_BASE_URL=https://www.gemcybersecurityassist.com
# Optional rotation overrides. When absent, independent domain-separated values
# are derived from JWT_SECRET inside the Node.js server runtime.
GEM_VERIFY_SCANNER_TOKEN=
GEM_VERIFY_SCANNER_CALLBACK_SECRET=
# Stale scan enforcement runs inside Supabase through pg_cron every 10 minutes.
# No Vercel CRON_SECRET is required.
# Keep these false until the synthetic scan test, retention approval and operations review pass.
GEM_VERIFY_RETENTION_APPROVED=false
GEM_VERIFY_EVIDENCE_APPROVED=false
GEM_VERIFY_DOCUMENT_UPLOAD_ACTIVE=false

# --- Production Safety Gates -------------------------------------------------
RUN_DB_MIGRATIONS=false
AUTO_DB_PUSH=false
AUTO_DB_SEED=false
SEED_DEMO_DATA=false

# --- Admin Bootstrap ---------------------------------------------------------
ADMIN_EMAIL=admin@example.com
# Only use during a controlled first bootstrap. Remove after the administrator exists.
ADMIN_INITIAL_PASSWORD=replace-with-temporary-password

# --- Audit Logging -----------------------------------------------------------
AUDIT_ENABLED=true

# --- TokMetric production gates and integrations -----------------------------
# Production Direct Post remains blocked unless this is explicitly true.
TOKMETRIC_LIVE_PUBLISHING_ENABLED=false
# Sandbox Direct Post remains blocked unless this is explicitly true.
TOKMETRIC_SANDBOX_PUBLISHING_ENABLED=false
# Comma-separated domains already verified in TikTok Developer Portal → URL properties.
# Required only for PULL_FROM_URL. Local files use FILE_UPLOAD directly to TikTok.
TOKMETRIC_VERIFIED_MEDIA_HOSTS=gemcybersecurityassist.com,www.gemcybersecurityassist.com
TOKMETRIC_TIKTOK_CLIENT_KEY=
TOKMETRIC_TIKTOK_CLIENT_SECRET=
TOKMETRIC_TIKTOK_OAUTH_REDIRECT_URL=https://gemcybersecurityassist.com/api/tokmetric/oauth/callback
TOKMETRIC_TOKEN_ENCRYPTION_KEY=
TOKMETRIC_WEBHOOK_VERIFICATION_SECRET=

# Canonical production Custom GPT transport. The bearer token itself is entered
# in the Custom GPT Action authentication settings and is stored only as a
# SHA-256 hash in Supabase; it is not added to Vercel or committed to Git.
GEM_TOKMETRIC_GPT_GATEWAY_ENABLED=true
GEM_TOKMETRIC_GPT_GATEWAY_URL=https://your-project-ref.supabase.co/functions/v1/gem-tokmetric-gpt-gateway
GEM_TOKMETRIC_AGENT_GATEWAY_ENABLED=true
GEM_TOKMETRIC_AGENT_GATEWAY_URL=https://your-project-ref.supabase.co/functions/v1/gem-tokmetric-agent-gateway
# Legacy/direct-Prisma fallback only. Leave blank when the Supabase gateway is enabled.
GPT_AUTH_TOKEN=
TOKMETRIC_GPT_ACTOR_USER_ID=

# TikTok OAuth connector configuration
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://gemcybersecurityassist.com/api/tokmetric/oauth/callback
TIKTOK_ENVIRONMENT=sandbox
TOKMETRIC_TIKTOK_OAUTH_ENABLED=false

# TokMetric idempotency records default to 24 hours when unset or malformed.
TOKMETRIC_IDEMPOTENCY_TTL_SECONDS=86400

# --- Cross-platform social media readiness ----------------------------------
# Global emergency gate. Keep false until each provider is separately certified.
SOCIAL_MEDIA_LIVE_PUBLISHING_ENABLED=false
# Shared encryption key for non-TikTok OAuth credentials. Use exactly 32 random bytes.
SOCIAL_TOKEN_ENCRYPTION_KEY=
# Optional dedicated signing secret for OAuth state. JWT_SECRET is used when omitted.
SOCIAL_OAUTH_STATE_SECRET=

# Meta: Facebook Pages and Instagram professional accounts
META_SOCIAL_OAUTH_ENABLED=false
META_SOCIAL_PUBLISHING_ENABLED=false
META_GRAPH_API_VERSION=
META_APP_ID=
META_APP_SECRET=
META_SOCIAL_SCOPES=pages_show_list pages_read_engagement pages_manage_posts instagram_basic instagram_content_publish
META_OAUTH_REDIRECT_URI=https://gemcybersecurityassist.com/api/social-media/oauth/meta/callback

# X company account
X_SOCIAL_OAUTH_ENABLED=false
X_SOCIAL_PUBLISHING_ENABLED=false
X_CLIENT_ID=
X_CLIENT_SECRET=
X_SOCIAL_SCOPES=tweet.read tweet.write users.read offline.access
X_OAUTH_REDIRECT_URI=https://gemcybersecurityassist.com/api/social-media/oauth/x/callback

# Nextdoor verified identity or business page. Enable only after Publish API access is approved.
NEXTDOOR_PUBLISH_API_ACCESS_APPROVED=false
NEXTDOOR_OAUTH_ENABLED=false
NEXTDOOR_PUBLISHING_ENABLED=false
NEXTDOOR_CLIENT_ID=
NEXTDOOR_CLIENT_SECRET=
NEXTDOOR_SOCIAL_SCOPES=openid post:write post:read profile:read
NEXTDOOR_OAUTH_REDIRECT_URI=https://gemcybersecurityassist.com/api/social-media/oauth/nextdoor/callback

# Indeed employer workflow. This is for genuine vacancies and employer updates only.
INDEED_EMPLOYER_INTEGRATION_ENABLED=false
INDEED_JOB_PUBLISHING_ENABLED=false
INDEED_EMPLOYER_ID=
INDEED_JOB_FEED_URL=

# LinkedIn company organization. Enable only after required product access is approved.
LINKEDIN_COMMUNITY_MANAGEMENT_ACCESS_APPROVED=false
LINKEDIN_SOCIAL_OAUTH_ENABLED=false
LINKEDIN_SOCIAL_PUBLISHING_ENABLED=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_SOCIAL_SCOPES=w_organization_social r_organization_social
LINKEDIN_API_VERSION=
LINKEDIN_OAUTH_REDIRECT_URI=https://gemcybersecurityassist.com/api/social-media/oauth/linkedin/callback

# YouTube Brand Account or authorized channel. Public upload requires project verification/audit.
YOUTUBE_DATA_API_AUDIT_APPROVED=false
YOUTUBE_SOCIAL_OAUTH_ENABLED=false
YOUTUBE_PUBLISHING_ENABLED=false
GOOGLE_SOCIAL_CLIENT_ID=
GOOGLE_SOCIAL_CLIENT_SECRET=
YOUTUBE_SOCIAL_SCOPES=https://www.googleapis.com/auth/youtube.upload
YOUTUBE_OAUTH_REDIRECT_URI=https://gemcybersecurityassist.com/api/social-media/oauth/youtube/callback

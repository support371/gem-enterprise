# =============================================================================
# GEM Enterprise — Environment Variable Template
# =============================================================================
# Copy this file to .env.local and fill in real values before running locally.
# Never commit .env.local or any file that contains real secrets.
#
# For Vercel deployment: add these variables in
# Vercel Dashboard → Project → Settings → Environment Variables
# Do NOT paste secrets into vercel.json — use Vercel Project Settings only.
# =============================================================================

# --- Database ----------------------------------------------------------------
POSTGRES_PRISMA_URL=postgresql://username:password@localhost:5432/gem_enterprise
POSTGRES_URL_NON_POOLING=postgresql://username:password@localhost:5432/gem_enterprise

# --- Authentication ----------------------------------------------------------
# Must be at least 32 characters in production.
JWT_SECRET=replace-this-with-a-random-32-char-secret
# Separate signing secret recommended for 15-minute password reset links.
# When omitted, the application falls back to JWT_SECRET.
PASSWORD_RESET_SECRET=replace-this-with-a-different-random-32-char-secret

# --- AI / Governed Chat ------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-replace-with-real-key
NEXT_PUBLIC_AI_DISCLOSURE_TEXT=GEM Concierge is an AI assistant. It does not provide legal, financial, or investment advice. Responses are for informational purposes only. For regulated matters, speak with a qualified advisor.

# --- Application -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-deployment-url.vercel.app
NEXT_PUBLIC_APP_NAME=GEM Enterprise

# --- Email / SMTP ------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-smtp-password
EMAIL_FROM=GEM Enterprise <noreply@example.com>
REPLY_TO_EMAIL=support@example.com

# --- Admin Bootstrap ---------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=replace-with-temporary-password

# --- Audit Logging -----------------------------------------------------------
AUDIT_ENABLED=true

# TokMetric production gates and integrations (placeholders only)
TOKMETRIC_LIVE_PUBLISHING_ENABLED=false
TOKMETRIC_TIKTOK_CLIENT_KEY=
TOKMETRIC_TIKTOK_CLIENT_SECRET=
TOKMETRIC_TIKTOK_OAUTH_REDIRECT_URL=https://gemcybersecurityassist.com/api/tokmetric/oauth/callback
TOKMETRIC_TOKEN_ENCRYPTION_KEY=
TOKMETRIC_WEBHOOK_VERIFICATION_SECRET=
GPT_AUTH_TOKEN=

# TikTok OAuth connector configuration (Phase 2 placeholders only)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://gemcybersecurityassist.com/api/tokmetric/oauth/callback
TIKTOK_ENVIRONMENT=sandbox
TOKMETRIC_TIKTOK_OAUTH_ENABLED=false

# TokMetric idempotency records default to 24 hours when unset or malformed.
TOKMETRIC_IDEMPOTENCY_TTL_SECONDS=86400

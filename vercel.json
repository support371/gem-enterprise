{
  "framework": "nextjs",
  "buildCommand": "pnpm run db:generate && pnpm exec next build --webpack",
  "installCommand": "pnpm install --frozen-lockfile",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "env": {
    "AUDIT_ENABLED": "true",
    "NEXT_PUBLIC_APP_NAME": "GEM Enterprise"
  }
}

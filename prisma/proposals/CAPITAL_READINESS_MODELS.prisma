  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  matter    CapitalMatter            @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documents CapitalDocument[]
  accessGrants CapitalDataRoomAccess[]

  @@index([workspaceId, matterId])
  @@map("capital_data_rooms")
}

model CapitalDocument {
  id                   String                     @id @default(cuid())
  dataRoomId           String
  category             String
  title                String
  confidentialityLevel CapitalConfidentialityLevel
  status               CapitalDocumentStatus      @default(DRAFT)
  currentVersion       Int                         @default(0)
  ownerId              String
  effectiveAt          DateTime?
  expiresAt            DateTime?
  downloadAllowed      Boolean                     @default(false)
  watermarkRequired    Boolean                     @default(true)
  legalHoldActive      Boolean                     @default(false)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  dataRoom CapitalDataRoom        @relation(fields: [dataRoomId], references: [id], onDelete: Cascade)
  versions CapitalDocumentVersion[]

  @@index([dataRoomId, category, status])
  @@map("capital_documents")
}

model CapitalDocumentVersion {
  id             String   @id @default(cuid())
  documentId     String
  version        Int
  storageRef     String
  fileName       String
  mimeType       String
  fileSize       Int
  checksum       String
  sourceRef      String?
  redactionStatus String   @default("NOT_REVIEWED")
  approvedById   String?
  approvedAt     DateTime?
  supersedesVersion Int?
  createdById    String
  createdAt      DateTime @default(now())

  document CapitalDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@unique([documentId, version])
  @@unique([documentId, checksum])
  @@map("capital_document_versions")
}

model CapitalDataRoomAccess {
  id                  String                     @id @default(cuid())
  dataRoomId          String
  granteeType         String
  granteeRef          String
  confidentialityLevel CapitalConfidentialityLevel
  canView             Boolean                    @default(true)
  canDownload         Boolean                    @default(false)
  grantedById         String
  approvedByPartnerRef String?
  expiresAt           DateTime
  revokedAt           DateTime?
  createdAt           DateTime                   @default(now())

  dataRoom CapitalDataRoom @relation(fields: [dataRoomId], references: [id], onDelete: Cascade)

  @@index([dataRoomId, granteeRef, expiresAt])
  @@map("capital_data_room_access")
}

model CapitalDiligenceQuestion {
  id               String                  @id @default(cuid())
  matterId         String
  category         String
  question         String
  status           CapitalDiligenceStatus  @default(DRAFT)
  disclosureRestriction CapitalConfidentialityLevel @default(CLIENT_CONFIDENTIAL)
  raisedByRef      String?
  assignedToId     String?
  dueAt            DateTime?
  riskRef          String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  matter    CapitalMatter               @relation(fields: [matterId], references: [id], onDelete: Cascade)
  responses CapitalDiligenceResponse[]

  @@index([matterId, status, dueAt])
  @@map("capital_diligence_questions")
}

model CapitalDiligenceResponse {
  id             String   @id @default(cuid())
  questionId     String
  response       String
  evidenceRefs   String[] @default([])
  respondentId   String
  reviewerId     String?
  reviewedAt     DateTime?
  approvedAt     DateTime?
  version        Int
  createdAt      DateTime @default(now())

  question CapitalDiligenceQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, version])
  @@map("capital_diligence_responses")
}

model CapitalProposal {
  id             String                @id @default(cuid())
  matterId       String
  targetEntryId  String?
  status         CapitalProposalStatus
  instrument     String
  proposedAmount Decimal?              @db.Decimal(18, 2)
  currency       String                @default("USD")
  valuationOrPricing String?
  interestOrReturnTerms String?
  maturity       String?
  security       String?
  covenants      Json                  @default("{}")
  conditions     Json                  @default("{}")
  fees           Json                  @default("{}")
  exclusivity    String?
  expiresAt      DateTime?
  fundingCertainty CapitalReviewerConfidence @default(LOW)
  sourceLabel    CapitalSourceLabel
  sourceRef      String?
  partnerAssessment String?
  clientDecision String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  matter      CapitalMatter       @relation(fields: [matterId], references: [id], onDelete: Cascade)
  targetEntry CapitalTargetEntry? @relation(fields: [targetEntryId], references: [id], onDelete: SetNull)

  @@index([matterId, status, expiresAt])
  @@map("capital_proposals")
}

model CapitalClosingCondition {
  id          String   @id @default(cuid())
  matterId    String
  category    String
  description String
  ownerId     String?
  status      String   @default("OUTSTANDING")
  dueAt       DateTime?
  evidenceRef String?
  verifiedById String?
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matter CapitalMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId, status, dueAt])
  @@map("capital_closing_conditions")
}

model CapitalClosing {
  id                       String               @id @default(cuid())
  matterId                 String
  status                   CapitalClosingStatus @default(PRE_CLOSING)
  finalKybRefreshAt        DateTime?
  finalSanctionsRefreshAt  DateTime?
  partnerConfirmationRef   String?
  counselConfirmationRef   String?
  feeApprovalRef           String?
  fundsFlowVerifiedExternally Boolean           @default(false)
  noGemCustodyConfirmed    Boolean               @default(false)
  authorizedSignatoriesConfirmed Boolean         @default(false)
  scheduledAt              DateTime?
  closedAt                 DateTime?
  terminationReason        String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  matter CapitalMatter @relation(fields: [matterId], references: [id], onDelete: Restrict)

  @@index([matterId, status])
  @@map("capital_closings")
}

model CapitalServiceContract {
  id             String                @id @default(cuid())
  workspaceId    String
  matterId       String?
  title          String
  status         CapitalContractStatus @default(DRAFT)
  serviceTypes   CapitalRevenueType[]
  monthlyAmount  Decimal?              @db.Decimal(18, 2)
  annualAmount   Decimal?              @db.Decimal(18, 2)
  currency       String                @default("USD")
  startAt        DateTime?
  endAt          DateTime?
  signedAt       DateTime?
  approvedById   String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  matter    CapitalMatter?  @relation(fields: [matterId], references: [id], onDelete: SetNull)
  revenueEvents CapitalRevenueEvent[]

  @@index([workspaceId, status, startAt])
  @@map("capital_service_contracts")
}

model CapitalRevenueEvent {
  id             String             @id @default(cuid())
  workspaceId    String
  contractId     String?
  revenueType    CapitalRevenueType
  amount         Decimal            @db.Decimal(18, 2)
  currency       String             @default("USD")
  status         String             @default("PLANNED")
  trigger        String
  invoiceRef     String?
  paymentRef     String?
  occurredAt     DateTime?
  safeMetadata   Json               @default("{}")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  workspace Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  contract  CapitalServiceContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@map("capital_revenue_events")
}

model CapitalGovernedAgent {
  id                         String             @id @default(cuid())
  workspaceId                String
  name                       String
  purpose                    String
  status                     CapitalAgentStatus @default(DRAFT)
  defaultMode                String             @default("READ_ONLY")
  externalCommunicationMode String             @default("HUMAN_APPROVAL_REQUIRED")
  regulatedActivityMode     String             @default("LICENSED_PARTNER_REQUIRED")
  moneyMovementEnabled       Boolean            @default(false)
  custodyEnabled             Boolean            @default(false)
  criticalComplianceHumanOnly Boolean           @default(true)
  configuration             Json               @default("{}")
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  workspace Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  runs      CapitalGovernedAgentRun[]

  @@unique([workspaceId, name])
  @@index([workspaceId, status])
  @@map("capital_governed_agents")
}

model CapitalGovernedAgentRun {
  id                     String                @id @default(cuid())
  agentId                String
  status                 CapitalAgentRunStatus @default(QUEUED)
  matterId               String?
  requestedById          String
  activityClassification CapitalActivityClassification
  inputHash              String
  outputHash             String?
  evidenceRefs           String[]              @default([])
  confidence             CapitalReviewerConfidence?
  humanApprovalRef       String?
  partnerApprovalRef     String?
  complianceApprovalRef  String?
  errorCode              String?
  safeErrorMessage       String?
  startedAt              DateTime?
  completedAt            DateTime?
  createdAt              DateTime              @default(now())

  agent CapitalGovernedAgent @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@index([agentId, status, createdAt])
  @@index([matterId, createdAt])
  @@map("capital_governed_agent_runs")
}

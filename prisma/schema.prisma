// GEM Enterprise — Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  client
  analyst
  admin
  super_admin
  internal
}

enum UserStatus {
  active
  suspended
  pending_approval
}

enum KYCStatus {
  not_started
  started
  in_progress
  documents_uploaded
  under_review
  manual_review
  approved
  rejected
  expired
}

enum EntityType {
  individual
  business
  trust
  family_office
}

enum TicketStatus {
  open
  in_progress
  waiting_on_client
  resolved
  closed
}

enum RequestStatus {
  open
  in_progress
  pending_info
  completed
  cancelled
}

enum RequestPriority {
  low
  medium
  high
  critical
}

enum NotificationChannel {
  in_app
  email
  sms
  push
}

enum SupportSessionStatus {
  active
  escalated
  resolved
  closed
}

enum BookingStatus {
  pending
  confirmed
  rescheduled
  cancelled
  completed
}

enum AuditAction {
  login
  logout
  failed_login
  password_change
  role_change
  kyc_submit
  kyc_approve
  kyc_reject
  kyc_flag
  document_upload
  ai_session_opened
  ai_message_sent
  restricted_class_detected
  evidence_created
  case_created
  case_closed
  data_export
  admin_action
}

enum NewsCategory {
  crypto
  cybersecurity
  markets
  geopolitics
  policy
  real_estate
  alternatives
  general
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  passwordHash    String
  role            UserRole    @default(client)
  status          UserStatus  @default(active)
  organizationId  String?
  lastLoginAt     DateTime?
  isActive        Boolean     @default(true)
  isEmailVerified Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  profile         Profile?
  kycApplications KYCApplication[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  portfolioMemberships PortfolioMembership[]
  entitlements    Entitlement[]
  tickets         SupportTicket[]
  requests        ServiceRequest[]

  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String?
  lastName    String?
  displayName String?
  avatarUrl   String?
  bio         String?
  country     String?
  phone       String?
  entityType  EntityType?
  accreditedStatus Boolean? @default(false)
  preferences Json?    @default("{}")
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model KYCApplication {
  id              String   @id @default(cuid())
  userId          String
  status          KYCStatus @default(not_started)
  entityType      EntityType @default(individual)
  data            Json?
  formData        Json?
  submittedAt     DateTime?
  completedAt     DateTime?
  reviewedAt      DateTime?
  reviewerId      String?
  rejectionReason String?
  reviewNotes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  decision        Decision?
  documents       KycDocument[]
  reviews         KYCReview[]

  @@map("kyc_applications")
}

model KycDocument {
  id              String   @id @default(cuid())
  applicationId   String
  documentType    String
  storagePath     String
  fileName        String
  fileSize        Int
  mimeType        String
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  application     KYCApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

model Decision {
  id              String   @id @default(cuid())
  applicationId   String   @unique
  decision        String
  decisionBy      String
  decisionAt      DateTime @default(now())
  reason          String?

  application     KYCApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("decisions")
}

model KYCReview {
  id              String   @id @default(cuid())
  applicationId   String
  reviewerId      String
  action          String
  notes           String?
  createdAt       DateTime @default(now())

  application     KYCApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("kyc_reviews")
}

model Entitlement {
  id          String   @id @default(cuid())
  userId      String
  slug        String
  isActive    Boolean  @default(true)
  grantedBy   String?
  grantedAt   DateTime @default(now())
  notes       String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@map("entitlements")
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model Portfolio {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  totalValue  Decimal? @db.Decimal(18, 2)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships PortfolioMembership[]

  @@map("portfolios")
}

model PortfolioMembership {
  id          String   @id @default(cuid())
  portfolioId String
  userId      String
  role        String   @default("viewer")
  assignedBy  String?
  assignedAt  DateTime @default(now())

  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, userId])
  @@map("portfolio_memberships")
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  description String
  status      TicketStatus @default(open)
  priority    RequestPriority @default(medium)
  assignedTo  String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model ServiceRequest {
  id          String   @id @default(cuid())
  userId      String
  type        String
  subject     String
  description String
  status      RequestStatus @default(open)
  priority    RequestPriority @default(medium)
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("requests")
}

model SupportBooking {
  id          String   @id @default(cuid())
  sessionId   String?
  userId      String?
  name        String
  email       String
  subject     String
  preferredAt DateTime?
  status      BookingStatus @default(pending)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     SupportSession? @relation(fields: [sessionId], references: [id])

  @@map("support_bookings")
}

model SupportEscalation {
  id          String   @id @default(cuid())
  sessionId   String
  reason      String
  queue       String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  session     SupportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("support_escalations")
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  title       String
  body        String
  channel     NotificationChannel @default(in_app)
  isRead      Boolean   @default(false)
  readAt      DateTime?
  data        Json?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      AuditAction
  resource    String?
  resourceId  String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model AiRun {
  id                   String    @id @default(cuid())
  profileId            String
  modelVersion         String
  promptClass          String    @default("GENERAL")
  consentReceiptId     String
  disclosureTextHash   String
  transcriptPointer    String?
  escalationTriggered  Boolean   @default(false)
  escalationReason     String?
  outputStatus         String    @default("open")
  messageCount         Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  consentRecord        ConsentRecord?

  @@map("ai_runs")
}

model ConsentRecord {
  id                 String   @id @default(cuid())
  aiRunId            String   @unique
  userId             String?
  disclosureTextHash String
  consentGivenAt     DateTime @default(now())
  ipAddress          String?
  userAgent          String?

  aiRun              AiRun    @relation(fields: [aiRunId], references: [id], onDelete: Cascade)

  @@map("consent_records")
}

model NewsSource {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  feedUrl       String       @unique
  siteUrl       String?
  category      NewsCategory
  description   String?
  isActive      Boolean      @default(true)
  pollIntervalMinutes Int    @default(360)
  lastFetchedAt DateTime?
  lastSuccessAt DateTime?
  lastErrorAt   DateTime?
  lastError     String?
  consecutiveFailures Int    @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  articles      NewsArticle[]

  @@map("news_sources")
}

model NewsArticle {
  id             String            @id @default(cuid())
  sourceId       String?
  externalGuid   String            @unique
  externalUrl    String
  slug           String            @unique
  title          String
  summary        String?
  aiSummary      String?
  body           String?
  category       NewsCategory
  tags           String[]          @default([])
  author         String?
  mediaType      String            @default("none")
  imageUrl       String?
  imageAlt       String?
  videoUrl       String?
  videoThumbnail String?
  videoProvider  String?
  status         String            @default("published")
  isFeatured     Boolean           @default(false)
  isEditorsPick  Boolean           @default(false)
  relevanceScore Int               @default(0)
  publishedAt    DateTime
  ingestedAt     DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  source         NewsSource?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@map("news_articles")
}

model NewsIngestionRun {
  id               String   @id @default(cuid())
  status           String   @default("running")
  triggeredBy      String
  sourcesAttempted Int      @default(0)
  sourcesSucceeded Int      @default(0)
  sourcesFailed    Int      @default(0)
  articlesFound    Int      @default(0)
  articlesCreated  Int      @default(0)
  articlesUpdated  Int      @default(0)
  articlesSkipped  Int      @default(0)
  aiEnrichments    Int      @default(0)
  aiFailures       Int      @default(0)
  durationMs       Int?
  errorSummary     String?
  metadata         Json?
  startedAt        DateTime @default(now())
  completedAt      DateTime?

  @@map("news_ingestion_runs")
}

model SupportSession {
  id            String               @id @default(cuid())
  userId        String?
  userTier      String               @default("standard")
  status        SupportSessionStatus @default(active)
  consentGiven  Boolean              @default(false)
  consentAt     DateTime?
  messages      Json                 @default("[]")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  bookings      SupportBooking[]
  escalations   SupportEscalation[]

  @@map("support_sessions")
}

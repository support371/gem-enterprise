// GEM Enterprise — Prisma Schema
// Database: PostgreSQL (prod) / SQLite (local dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  client
  admin
  internal
  analyst
}

enum EntityType {
  individual
  business
  trust
  family_office
}

enum KYCStatus {
  not_started
  started
  in_progress
  documents_uploaded
  under_review
  manual_review
  approved
  rejected
  expired
}

enum DecisionType {
  approved
  rejected
  manual_review
  pending
}

enum DocumentType {
  government_id
  proof_of_address
  tax_document
  financial_statement
  trust_deed
  articles_of_incorporation
  beneficial_owner
  accredited_investor
  other
}

enum DocumentStatus {
  pending
  accepted
  rejected
  expired
}

enum RequestStatus {
  open
  in_progress
  resolved
  closed
  cancelled
}

enum RequestPriority {
  low
  medium
  high
  critical
}

enum TicketStatus {
  open
  in_progress
  waiting_client
  resolved
  closed
}

enum NotificationChannel {
  in_app
  email
  sms
}

enum AuditAction {
  login
  logout
  session_expired
  kyc_start
  kyc_submit
  kyc_document_upload
  kyc_approved
  kyc_rejected
  kyc_manual_review
  user_created
  user_updated
  user_deleted
  admin_action
  entitlement_granted
  entitlement_revoked
  portfolio_assigned
  support_ticket_created
  request_submitted
  document_viewed
  password_reset
  support_session_started
  support_session_closed
  support_consent_given
  support_escalated
  support_booking_created
  ai_session_opened
  ai_message_responded
  ai_message_escalated
  ai_session_closed
}

enum SupportSessionStatus {
  active
  escalated
  closed
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  role             UserRole  @default(client)
  isActive         Boolean   @default(true)
  isEmailVerified  Boolean   @default(false)
  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile          UserProfile?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  organizationId   String?

  kycApplications  KYCApplication[]
  entitlements     Entitlement[]
  portfolios       PortfolioMembership[]
  supportTickets   SupportTicket[]
  requests         Request[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  sessions         UserSession[]

  @@map("users")
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  ipAddress   String?
  userAgent   String?
  isRevoked   Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model UserProfile {
  id             String     @id @default(cuid())
  userId         String     @unique
  firstName      String?
  lastName       String?
  displayName    String?
  phone          String?
  country        String?
  state          String?
  city           String?
  zipCode        String?
  address        String?
  dateOfBirth    DateTime?
  entityType     EntityType @default(individual)
  taxId          String?
  accreditedStatus Boolean  @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Organization {
  id             String     @id @default(cuid())
  name           String
  entityType     EntityType
  registrationNo String?
  jurisdiction   String?
  incorporatedAt DateTime?
  website        String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  users          User[]
  portfolios     Portfolio[]

  @@map("organizations")
}

// ─── KYC Models ───────────────────────────────────────────────────────────────

model KYCApplication {
  id              String     @id @default(cuid())
  userId          String
  entityType      EntityType
  status          KYCStatus  @default(not_started)
  submittedAt     DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  reviewNotes     String?
  internalNotes   String?
  riskScore       Int?
  assignedReviewer String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Form data (JSONB)
  formData        Json?

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents       KYCDocument[]
  reviews         KYCReview[]
  decision        Decision?

  @@map("kyc_applications")
}

model KYCDocument {
  id              String         @id @default(cuid())
  applicationId   String
  documentType    DocumentType
  status          DocumentStatus @default(pending)
  fileName        String
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  uploadedAt      DateTime       @default(now())
  reviewedAt      DateTime?
  expiresAt       DateTime?
  rejectionReason String?

  application     KYCApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

model KYCReview {
  id              String     @id @default(cuid())
  applicationId   String
  reviewerId      String
  action          DecisionType
  notes           String?
  createdAt       DateTime   @default(now())

  application     KYCApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("kyc_reviews")
}

model Decision {
  id              String       @id @default(cuid())
  applicationId   String       @unique
  decision        DecisionType
  decisionBy      String
  decisionAt      DateTime     @default(now())
  reason          String?
  conditions      String?
  validUntil      DateTime?

  application     KYCApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("decisions")
}

// ─── Entitlements & Products ──────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  category    String   // cyber | financial | real-estate
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entitlements Entitlement[]

  @@map("products")
}

model Entitlement {
  id          String   @id @default(cuid())
  userId      String
  productId   String?
  slug        String   // e.g. "cyber", "financial", "real-estate"
  grantedBy   String
  grantedAt   DateTime @default(now())
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  notes       String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("entitlements")
}

// ─── Portfolios ───────────────────────────────────────────────────────────────

model Portfolio {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String?
  category       String?  // cyber | financial | real-estate
  totalValue     Decimal? @db.Decimal(18, 2)
  currency       String   @default("USD")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization?        @relation(fields: [organizationId], references: [id])
  members        PortfolioMembership[]

  @@map("portfolios")
}

model PortfolioMembership {
  id          String   @id @default(cuid())
  portfolioId String
  userId      String
  role        String   @default("viewer") // owner | manager | viewer
  assignedBy  String?
  assignedAt  DateTime @default(now())

  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, userId])
  @@map("portfolio_memberships")
}

// ─── Support & Requests ───────────────────────────────────────────────────────

model SupportTicket {
  id          String        @id @default(cuid())
  userId      String
  subject     String
  description String
  status      TicketStatus  @default(open)
  priority    RequestPriority @default(medium)
  assignedTo  String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  isInternal Boolean @default(false)
  createdAt DateTime @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

model Request {
  id          String          @id @default(cuid())
  userId      String
  type        String          // service_change | allocation | access | withdrawal | other
  subject     String
  description String
  status      RequestStatus   @default(open)
  priority    RequestPriority @default(medium)
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("requests")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String              @id @default(cuid())
  userId      String
  title       String
  body        String
  channel     NotificationChannel @default(in_app)
  isRead      Boolean             @default(false)
  readAt      DateTime?
  data        Json?
  createdAt   DateTime            @default(now())

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  resource    String?     // "kyc_application", "user", "portfolio" etc.
  resourceId  String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── Campaign / Notification Outbox ──────────────────────────────────────────

model Contact {
  id          String   @id @default(cuid())
  email       String   @unique
  firstName   String?
  lastName    String?
  tags        String[] @default([])
  isSubscribed Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  segments    SegmentMembership[]
  recipients  CampaignRecipient[]

  @@map("contacts")
}

model Segment {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     SegmentMembership[]
  campaigns   Campaign[]

  @@map("segments")
}

model SegmentMembership {
  id          String   @id @default(cuid())
  segmentId   String
  contactId   String

  segment     Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([segmentId, contactId])
  @@map("segment_memberships")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  subject     String?
  body        String?
  segmentId   String?
  status      String   @default("draft") // draft | scheduled | sending | sent | cancelled
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  segment     Segment?           @relation(fields: [segmentId], references: [id])
  recipients  CampaignRecipient[]

  @@map("campaigns")
}

model CampaignRecipient {
  id          String   @id @default(cuid())
  campaignId  String
  contactId   String
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  status      String   @default("pending")

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@map("campaign_recipients")
}

model OutboxMessage {
  id          String   @id @default(cuid())
  channel     String   // email | sms | webhook
  recipient   String
  subject     String?
  body        String
  metadata    Json?
  sentAt      DateTime?
  failedAt    DateTime?
  retryCount  Int      @default(0)
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  @@map("outbox_messages")
}

model SuppressionList {
  id          String   @id @default(cuid())
  email       String   @unique
  reason      String?
  suppressedAt DateTime @default(now())

  @@map("suppression_list")
}

// ─── Support Chat Sessions ────────────────────────────────────────────────────

model SupportSession {
  id            String               @id @default(cuid())
  userId        String?
  userTier      String               @default("standard")
  status        SupportSessionStatus @default(active)
  consentGiven  Boolean              @default(false)
  consentAt     DateTime?
  messages      Json                 @default("[]")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  bookings      SupportBooking[]
  escalations   SupportEscalation[]

  @@map("support_sessions")
}

model SupportEscalation {
  id          String   @id @default(cuid())
  sessionId   String
  reason      String
  queue       String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  session     SupportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("support_escalations")
}

model SupportBooking {
  id          String        @id @default(cuid())
  sessionId   String?
  userId      String?
  name        String
  email       String
  subject     String
  preferredAt DateTime?
  status      BookingStatus @default(pending)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  session     SupportSession? @relation(fields: [sessionId], references: [id])

  @@map("support_bookings")
}

// ─── AI Governance ────────────────────────────────────────────────────────────

model AiRun {
  id                   String    @id @default(cuid())
  profileId            String
  modelVersion         String
  promptClass          String    @default("GENERAL")
  consentReceiptId     String
  disclosureTextHash   String
  transcriptPointer    String?
  escalationTriggered  Boolean   @default(false)
  escalationReason     String?
  outputStatus         String    @default("open")  // open | closed | escalated
  messageCount         Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  consentRecord        ConsentRecord?
  escalationEvents     AiEscalationEvent[]

  @@map("ai_runs")
}

model ConsentRecord {
  id                 String   @id @default(cuid())
  aiRunId            String   @unique
  userId             String?
  disclosureTextHash String
  consentGivenAt     DateTime @default(now())
  ipAddress          String?
  userAgent          String?

  aiRun              AiRun    @relation(fields: [aiRunId], references: [id], onDelete: Cascade)

  @@map("consent_records")
}

model AiEscalationEvent {
  id             String   @id @default(cuid())
  aiRunId        String
  restrictedClass String
  messagePreview String
  createdAt      DateTime @default(now())

  aiRun          AiRun    @relation(fields: [aiRunId], references: [id], onDelete: Cascade)

  @@map("ai_escalation_events")
}
